# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*.local
.env.local

# DuckDB local files (in-memory DB used at runtime; .ddb only for local DBeaver access)
data/*.ddb
data/*.wal

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
